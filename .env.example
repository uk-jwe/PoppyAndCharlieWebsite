# Database
# Local dev: postgresql://payload:payload@localhost:5433/poppyandcharlie
# QNAP: uses gigrequest-db shared container
DATABASE_URL=postgresql://payload:payload@localhost:5433/poppyandcharlie

# Payload CMS secret — generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-here

# App URL — used for Payload admin redirects and CORS
NEXT_PUBLIC_APP_URL=http://localhost:3004
